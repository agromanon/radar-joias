# Radar Jóias — Production Environment Variables
# Copy this file to .env on your production server and fill in real values

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LLM Providers
LLM_API_KEY=your-openrouter-or-anthropic-key
LLM_PROVIDER=openrouter  # or "anthropic", "deepseek"

# Proxies (WebShare for CAIXA scraping)
PROXY_SERVICE=webshare
PROXY_URLS=your-webshare-proxy-string

# Notifications (Resend for email)
RESEND_API_KEY=your-resend-api-key

# Security
CRON_SECRET=your-random-secret-for-cron-jobs

# App URL (change in production)
NEXT_PUBLIC_APP_URL=https://your-domain.com